<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- WebView занимает весь экран -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Контейнер для Speed Dial (Выпадающее меню ролей) -->
    <LinearLayout
        android:id="@+id/speedDialContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="100dp"
        android:orientation="vertical"
        android:gravity="end"
        android:visibility="gone" />

    <!-- Floating Bottom Bar (Glassmorphism) -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_bar"
        android:elevation="16dp"
        android:outlineProvider="background"
        android:clipToOutline="true"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="12dp"
        android:weightSum="4">

        <!-- 🍕 Меню -->
        <LinearLayout
            android:id="@+id/itemMenu"
            style="@style/BottomBarItemStyle">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu" android:tint="#8899AABB"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Меню" android:textSize="10sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- 🤖 AI -->
        <LinearLayout
            android:id="@+id/itemAI"
            style="@style/BottomBarItemStyle">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_ai" android:tint="#8899AABB"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI" android:textSize="10sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- 🛒 Корзина -->
        <LinearLayout
            android:id="@+id/itemCart"
            style="@style/BottomBarItemStyle">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_cart" android:tint="#8899AABB"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Корзина" android:textSize="10sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ••• Ещё -->
        <LinearLayout
            android:id="@+id/itemMore"
            style="@style/BottomBarItemStyle">
            <ImageView android:id="@+id/iconMore" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_more" android:tint="#8899AABB"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ещё" android:textSize="10sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
